# Supabase (from Dashboard → Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Database (for migrations only – must be the SAME project as NEXT_PUBLIC_SUPABASE_URL above)
# Dashboard → Project [your project] → Database → Connection string → URI (use the password you set for the DB)
# Then run: npm run db:migrate
# DATABASE_URL=postgresql://postgres.[project-ref]:[YOUR_DB_PASSWORD]@aws-0-[region].pooler.supabase.com:6543/postgres

# Canonical site URL for quote API `url`, auth redirects, etc.
# Set on Vercel (Production) even if you use a custom domain — Supabase "Site URL"
# does not populate this. Prefer APP_URL (runtime, server) so links stay correct
# when the API is called via *.vercel.app.
# APP_URL=https://quotes.example.com
#
# Client-side / build: optional duplicate for browser code (e.g. settings previews)
# NEXT_PUBLIC_APP_URL=https://quotes.example.com
